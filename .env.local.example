# Notion CMS — copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored; never commit your token.

# 1) Create an internal integration at https://www.notion.so/my-integrations
#    and paste its "Internal Integration Secret" here.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) For BOOTSTRAP ONLY: a Notion page you've shared with the integration.
#    The 5 databases get created inside this page.
#    Copy the page's ID from its URL (the 32-char hex after the title).
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3) Filled in after running `npm run notion:bootstrap`
#    (or paste the IDs of databases you created yourself).
NOTION_DB_PROJECTS=
NOTION_DB_WORK=
NOTION_DB_VOLUNTEERING=
NOTION_DB_CONTRIBUTIONS=
NOTION_DB_TESTIMONIALS=

# --- Gemini chatbot ("Ask <name>'s AI") ---
# One or more Google AI Studio keys, comma-separated. When a free-tier key hits
# its rate limit, the next key is used automatically. Keys stay server-side.
# Get keys at https://aistudio.google.com/apikey
GEMINI_API_KEYS=key_one,key_two,key_three
GEMINI_MODEL=gemini-2.5-flash
